        <turbulent_kinetic_energy>0</turbulent_kinetic_energy>
        <turbulent_dissipation_rate>0</turbulent_dissipation_rate>
        <concentration_1>0</concentration_1>
        <concentration_2>0</concentration_2>
        <concentration_3>0</concentration_3>
        <concentration_4>0</concentration_4>
        <concentration_5>0</concentration_5>
      </ambient_att>
    </ambients>
    <fluids>
      <fluid_att>
        <name>Air</name>
        <conductivity_type>constant</conductivity_type>
        <conductivity>0.0261</conductivity>
        <viscosity_type>constant</viscosity_type>
        <viscosity>0.0000184</viscosity>
        <density_type>constant</density_type>
        <density>1.1614</density>
        <specific_heat>1008</specific_heat>
        <expansivity>0.003</expansivity>
        <diffusivity>0</diffusivity>
      </fluid_att>
    </fluids>
    <sources>
      <source_att>
        <name>Source_3W</name>
        <source_options>
          <option>
            <applies_to>temperature</applies_to>
            <type>total</type>
            <value>0</value>
            <power>3</power>
            <linear_coefficient>0</linear_coefficient>
          </option>
        </source_options>
      </source_att>
      <source_att>
        <name>Source_1W</name>
        <source_options>
          <option>
            <applies_to>temperature</applies_to>
            <type>total</type>
            <value>0</value>
            <power>1</power>
            <linear_coefficient>0</linear_coefficient>
          </option>
        </source_options>
      </source_att>
    </sources>
    <thermals>
      <thermal_att>
        <name>ColdPlate_60C</name>
        <thermal_model>fixed_temperature</thermal_model>
        <fixed_temperature>60</fixed_temperature>
      </thermal_att>
    </thermals>
  </attributes>
  <geometry>
