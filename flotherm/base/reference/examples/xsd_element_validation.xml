      </isotropic_material_att>
      <orthotropic_material_att>
        <name>Bump_Composite_Aniso</name>
        <x_conductivity>1.0</x_conductivity>
        <y_conductivity>25.0</y_conductivity>
        <z_conductivity>1.0</z_conductivity>
        <density>5000</density>
        <specific_heat>400</specific_heat>
        <electrical_resistivity>
          <type>constant</type>
          <resistivity_value>0</resistivity_value>
        </electrical_resistivity>
      </orthotropic_material_att>
    </materials>
    <ambients>
      <ambient_att>
        <name>Ambient</name>
        <pressure>0</pressure>
        <temperature>298.15</temperature>
        <radiant_temperature>298.15</radiant_temperature>
        <heat_transfer_coeff>0</heat_transfer_coeff>
