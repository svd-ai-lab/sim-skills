<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<!--
  Validation model for the XSD-first claims in sim-skills#9:
  - <orthotropic_material_att> with x/y/z_conductivity
  - <thermal_att thermal_model="fixed_temperature"> attached to a cuboid
  Derived from hbm_3block (Phase 1b) but with both elements swapped in.
-->
<xml_case>
  <name>HBM_XSD_validation</name>
  <model>
    <modeling>
      <solution>flow_heat</solution>
      <radiation>off</radiation>
      <dimensionality>3d</dimensionality>
      <transient>false</transient>
      <store_mass_flux>false</store_mass_flux>
      <store_heat_flux>false</store_heat_flux>
      <store_surface_temp>true</store_surface_temp>
      <store_grad_t>false</store_grad_t>
      <store_bn_sc>false</store_bn_sc>
      <store_power_density>false</store_power_density>
      <store_mean_radiant_temperature>false</store_mean_radiant_temperature>
      <compute_capture_index>false</compute_capture_index>
      <user_defined_subgroups>false</user_defined_subgroups>
      <store_lma>false</store_lma>
    </modeling>
    <turbulence>
      <type>turbulent</type>
      <turbulence_type>auto_algebraic</turbulence_type>
    </turbulence>
    <gravity>
      <type>normal</type>
      <normal_direction>neg_y</normal_direction>
      <value_type>user</value_type>
      <gravity_value>9.81</gravity_value>
    </gravity>
    <global>
      <datum_pressure>101325</datum_pressure>
      <radiant_temperature>298.15</radiant_temperature>
      <ambient_temperature>298.15</ambient_temperature>
      <concentration_1>0</concentration_1>
      <concentration_2>0</concentration_2>
      <concentration_3>0</concentration_3>
      <concentration_4>0</concentration_4>
      <concentration_5>0</concentration_5>
    </global>
  </model>
  <solve>
    <overall_control>
      <outer_iterations>500</outer_iterations>
      <fan_relaxation>1</fan_relaxation>
      <estimated_free_convection_velocity>0.2</estimated_free_convection_velocity>
      <solver_option>multi_grid</solver_option>
      <active_plate_conduction>false</active_plate_conduction>
      <use_double_precision>false</use_double_precision>
      <network_assembly_block_correction>false</network_assembly_block_correction>
      <freeze_flow>false</freeze_flow>
      <store_error_field>false</store_error_field>
    </overall_control>
  </solve>
  <grid>
    <system_grid>
      <smoothing>true</smoothing>
      <smoothing_type>v3</smoothing_type>
      <dynamic_update>true</dynamic_update>
      <x_grid>
        <min_size>0.0005</min_size>
        <grid_type>max_size</grid_type>
        <max_size>0.002</max_size>
        <smoothing_value>12</smoothing_value>
      </x_grid>
      <y_grid>
        <min_size>0.00001</min_size>
        <grid_type>max_size</grid_type>
        <max_size>0.0005</max_size>
        <smoothing_value>12</smoothing_value>
      </y_grid>
      <z_grid>
        <min_size>0.0005</min_size>
        <grid_type>max_size</grid_type>
        <max_size>0.002</max_size>
        <smoothing_value>12</smoothing_value>
      </z_grid>
    </system_grid>
  </grid>
  <attributes>
    <materials>
      <isotropic_material_att>
        <name>Silicon</name>
        <conductivity>148</conductivity>
        <density>2330</density>
        <specific_heat>700</specific_heat>
        <electrical_resistivity>
          <type>constant</type>
          <resistivity_value>0</resistivity_value>
        </electrical_resistivity>
      </isotropic_material_att>
      <isotropic_material_att>
        <name>Aluminum</name>
        <conductivity>205</conductivity>
        <density>2700</density>
        <specific_heat>900</specific_heat>
        <electrical_resistivity>
          <type>constant</type>
          <resistivity_value>0</resistivity_value>
