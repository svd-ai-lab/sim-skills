  manual load or if Flotherm was started with this project).

  If the project was imported via `sim exec '<path>.pack'` (which uses
  project_import), the project is already active — use solve_only.xml
  or just `sim exec 'solve'` instead.

  Verified on: 2026-04-02/03 and 2026-04-11, Flotherm 2504
  Result: 153,449 grid cells, steady-state converged, status 3 normal exit
-->
<xml_log_file version="1.0">
    <project_unlock project_name="Mobile_Demo_Steady_State"/>
    <project_load project_name="Mobile_Demo_Steady_State"/>
    <start start_type="solver"/>
</xml_log_file>
