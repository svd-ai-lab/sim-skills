# Step 1: Lennard-Jones liquid NVT equilibration (verified E2E)
# Acceptance: after 50 steps, Temp in 0.5..2.5 (target 1.5)
# Observed: final temp ~1.48 on stable_29Aug2024 build
#
# Run: sim run 01_lj_nvt.in --solver lammps
# Output: log.lammps (with thermo Step Temp Press PotEng TotEng)
#
units           lj
atom_style      atomic
dimension       3
boundary        p p p

lattice         fcc 0.8442
region          box block 0 5 0 5 0 5
create_box      1 box
create_atoms    1 box
mass            1 1.0

velocity        all create 1.5 12345 mom yes rot yes

pair_style      lj/cut 2.5
pair_coeff      1 1 1.0 1.0 2.5

neighbor        0.3 bin
neigh_modify    every 20 delay 0 check no

fix             1 all nvt temp 1.5 1.5 0.1

thermo          10
thermo_style    custom step temp press pe etotal

run             50
