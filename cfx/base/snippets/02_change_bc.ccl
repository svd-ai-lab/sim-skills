# Snippet 02: Modify boundary condition via CCL override
# Usage: cfx5solve -batch -def <file.def> -ccl 02_change_bc.ccl
# Expected: inlet velocity changed from original to 3 m/s

FLOW: Flow Analysis 1
  DOMAIN: Default Domain
    BOUNDARY: inlet
      BOUNDARY CONDITIONS:
        MASS AND MOMENTUM:
          Normal Speed = 3 [m s^-1]
          Option = Normal Speed
        END
      END
    END
  END
END
COMMAND FILE:
  Version = 24.1
END
